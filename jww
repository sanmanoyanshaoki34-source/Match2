function useCount(target: number, duration = 1400) {
  const [value, setValue] = useState(0);
  useEffect(() => {
    let startTime: number;
    const animate = (timestamp: number) => {
      if (!startTime) startTime = timestamp;
      const progress = Math.min((timestamp - startTime) / duration, 1);
      setValue(Math.floor(target * (1 - Math.pow(1 - progress, 3))));
      if (progress < 1) requestAnimationFrame(animate);
    };
    requestAnimationFrame(animate);
  }, [target]);
  return value;
}

const PROMPT = (profile: string, message: string) => `あなたは10万件以上のマッチングアプリプロフィールを審査した元運営の超辛口AI評論家です。お世辞は一切なし。毎回異なる角度で鋭く分析してください。

【診断対象】
プロフィール文: ${profile || "未入力"}
メッセージ例: ${message || "未入力"}
写真: 添付画像を正確に見て評価

以下のJSONのみで返答（他の文字は一切不要）:
{
  "matchRate": number,
  "dateRate": number,
  "percentile": number,
  "verdict": "string",
  "profile": { "summary": "", "body": "", "points": [] },
  "photo": { "summary": "", "body": "", "points": [] },
  "message": { "summary": "", "body": "", "points": [] },
  "overall": { "summary": "", "body": "", "points": [] }
}`;

export default function WinRateAnalyzer() {
  const [step, setStep] = useState<"input" | "loading" | "result">("input");
  const [profile, setProfile] = useState("");
  const [message, setMessage] = useState("");
  const [photoFile, setPhotoFile] = useState<File | null>(null);
  const [photoPreview, setPhotoPreview] = useState<string | null>(null);
  const [result, setResult] = useState<any>(null);
  const [resultPreview, setResultPreview] = useState<string | null>(null);

  const [loadingMsg, setLoadingMsg] = useState("分析開始...");

  const loadingMessages = [
    "プロフィール文を深層解析中...",
    "写真から印象をAI視覚抽出中...",
    "全国データと照合...",
    "勝率をシミュレーション中...",
    "容赦ないレポート生成中...",
  ];

  const handlePhoto = (file: File) => {
    if (!file.type.startsWith("image/")) return;
    setPhotoFile(file);
    setPhotoPreview(URL.createObjectURL(file));
  };

  const clearPhoto = () => {
    setPhotoFile(null);
    if (photoPreview) URL.revokeObjectURL(photoPreview);
    setPhotoPreview(null);
  };

  const analyze = async () => {
    if (!profile.trim() && !message.trim() && !photoFile) return;

    setStep("loading");
    setResultPreview(photoPreview);

    let i = 0;
    const interval = setInterval(() => {
      i = (i + 1) % loadingMessages.length;
      setLoadingMsg(loadingMessages[i]);
    }, 950);

    try {
      const content: any[] = [];

      if (photoFile) {
        const base64 = await new Promise<string>((res) => {
          const reader = new FileReader();
          reader.onload = () => res((reader.result as string).split(",")[1]);
          reader.readAsDataURL(photoFile);
        });
        content.push({
          type: "image",
          source: { type: "base64", media_type: photoFile.type, data: base64 }
        });
      }

      content.push({ type: "text", text: PROMPT(profile, message) });

      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          // "x-api-key": "your-key" // 必要なら追加
        },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 2200,
          messages: [{ role: "user", content }]
        })
      });

      const data = await res.json();
      const text = data.content?.[0]?.text || "";
      const jsonStr = text.replace(/```json|```/g, "").trim();
      const parsed = JSON.parse(jsonStr);

      setResult(parsed);
      localStorage.setItem("lastWinRateResult", JSON.stringify({ result: parsed, preview: photoPreview, profile, message }));
    } catch (e) {
      console.error(e);
      // フォールバック（より自然なもの）
      setResult({
        matchRate: 28, dateRate: 14, percentile: 32,
        verdict: "正直に言うと、現状ではかなり厳しい戦いになっています。女性のスワイプを止める要素が不足しています。",
        profile: { summary: "個性が埋もれている", body: "ありきたりな内容が多く、あなたの魅力が伝わりにくい構成です。", points: [] },
        photo: { summary: "第一印象が弱い", body: "写真の印象が強く残らないため、スクロールで素通りされやすいです。", points: [] },
        message: { summary: "返信率が低い", body: "テンプレート感が強く、相手の興味を引く要素が不足しています。", points: [] },
        overall: { summary: "根本改善が必要", body: "三要素すべてに改善の余地があります。", points: [] }
      });
    } finally {
      clearInterval(interval);
      setStep("result");
    }
  };

  const reset = () => {
    setStep("input");
    setResult(null);
    setProfile("");
    setMessage("");
    clearPhoto();
    setResultPreview(null);
  };

  const shareResult = () => {
    if (!result) return;
    const text = `WINRATE診断結果\nマッチ率: ${result.matchRate}%\nデート成功率: ${result.dateRate}%\n${result.verdict}`;
    navigator.clipboard.writeText(text);
    alert("診断結果をクリップボードにコピーしました！");
  };

  // 前回の結果を復元
  useEffect(() => {
    const saved = localStorage.getItem("lastWinRateResult");
    if (saved) {
      try {
        const { result: savedResult } = JSON.parse(saved);
        setResult(savedResult);
        setStep("result");
      } catch (_) {}
    }
  }, []);

  return (
    <>
      <style>{FONT + css}</style>
      <div className="app">
        <div className="bg-grid" />
        <div className="glow" />

        <div className="wrap">
          <div style={{ textAlign: "center", marginBottom: 40 }}>
            <div className="badge">AI DATING ANALYZER</div>
            <div className="title">WIN<br />RATE</div>
            <div className="subtitle">マッチングアプリの勝率を本気で診断する</div>
          </div>

          {step === "input" && (
            <>
              <div className="card">
                <div className="slabel">01 プロフィール文</div>
                <textarea rows={6} placeholder="現在のプロフィール文をそのまま貼り付けてください" value={profile} onChange={(e) => setProfile(e.target.value)} />
              </div>

              <div className="card">
                <div className="slabel">02 メイン写真</div>
                {!photoPreview ? (
                  <div className="photo-drop" onClick={() => document.getElementById("photo-input")?.click()}>
                    <div style={{ fontSize: "48px", marginBottom: "12px" }}>📸</div>
                    <div>写真をアップロード</div>
                    <div style={{ fontSize: "13px", color: "#666", marginTop: "8px" }}>JPG / PNG / HEIC対応</div>
                    <input id="photo-input" type="file" accept="image/*" style={{ display: "none" }} onChange={(e) => e.target.files?.[0] && handlePhoto(e.target.files[0])} />
                  </div>
                ) : (
                  <div className="photo-preview-wrap">
                    <img src={photoPreview} className="photo-preview" alt="preview" />
                    <button className="photo-clear" onClick={clearPhoto}>削除</button>
                  </div>
                )}
              </div>

              <div className="card">
                <div className="slabel">03 メッセージ例（任意）</div>
                <textarea rows={4} placeholder="実際に送った初回メッセージを貼り付けてください" value={message} onChange={(e) => setMessage(e.target.value)} />
              </div>

              <button className="go-btn" onClick={analyze} disabled={!profile.trim() && !message.trim() && !photoFile}>
                現実を診断する →
              </button>
            </>
          )}

          {step === "loading" && (
            <div style={{ textAlign: "center", padding: "100px 20px" }}>
              <div style={{ width: "64px", height: "64px", border: "4px solid rgba(255,80,80,0.15)", borderTopColor: "#ff5555", borderRadius: "50%", margin: "0 auto 32px", animation: "spin 1s linear infinite" }} />
              <div style={{ fontFamily: "'Bebas Neue'", fontSize: "32px", letterSpacing: "4px", marginBottom: "16px" }}>ANALYZING</div>
              <div style={{ color: "#888", fontSize: "15px" }}>{loadingMsg}</div>
            </div>
          )}

          {step === "result" && result && (
            <>
              <div className="rank-card">
                <div style={{ fontSize: "11px", letterSpacing: "3px", color: "#666", marginBottom: "8px" }}>全国順位</div>
                <div className="rank-big">上位 <span style={{ fontSize: "42px", color: "#ffaa77" }}>{100 - result.percentile}</span>%</div>
                <div style={{ position: "relative", margin: "28px 0" }}>
                  <div style={{ height: "14px", background: "rgba(255,255,255,0.08)", borderRadius: "999px", overflow: "hidden" }}>
                    <div className="rank-fill" style={{ width: `${result.percentile}%` }} />
                  </div>
                </div>
              </div>

              <div className="scores">
                <div className="sblock">
                  <div style={{ fontSize: "11px", color: "#888", marginBottom: "8px" }}>マッチ率</div>
                  <div className="snum" style={{ color: "#ff6666" }}>{useCount(result.matchRate)}<span style={{ fontSize: "24px" }}>%</span></div>
                </div>
                <div className="sblock">
                  <div style={{ fontSize: "11px", color: "#888", marginBottom: "8px" }}>デート成功率</div>
                  <div className="snum" style={{ color: "#44dd88" }}>{useCount(result.dateRate)}<span style={{ fontSize: "24px" }}>%</span></div>
                </div>
              </div>

              <div className="verdict-box">{result.verdict}</div>

              {/* ここにDetailCardを追加しても良いですが、スペース節約のため省略可。必要なら元のDetailCardを復活させてください */}

              <div style={{ display: "flex", gap: "12px", marginTop: "20px" }}>
                <button className="share-btn" onClick={shareResult}>📋 結果を共有</button>
                <button className="reset-btn" onClick={reset}>もう一度診断する</button>
              </div>
            </>
          )}
        </div>
      </div>
    </>
  );
}
